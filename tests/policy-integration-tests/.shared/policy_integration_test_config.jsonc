{
  "tags": {
    "SolutionID": "12345",
    "owner": "cloud-platform-team",
    "dataclass": "official",
    "supportteam": "cloud-platform-team"
  }, //tags to be applied to all resources created by the tests
  "namePrefix": "poltest", //prefix to be applied to the names of all resources created by the tests. This helps to easily identify and filter test resources in the Azure portal.
  "deploymentPrefix": "poltest", //prefix to be applied to the names of all deployments created by the tests. This helps to easily identify and filter test deployments in the Azure portal.
  "privateDNSSubscription": "sub-d-mgmt-01", //subscription where the private DNS zones are located. This is needed to create private endpoints in the tests.
  "privateDNSResourceGroup": "rg-dev-network-01", //resource group where the private DNS zones are located. This is needed to create private endpoints in the tests.
  "testBicepTemplateName": "main.test.bicep", //name of the bicep template used for testing. This template should be located in the directory of each test case. if it is not found, the test will not deploy any Bicep templates during testing.
  "testTerraformDirectoryName": "main-test-terraform", //name of the directory containing the terraform configuration used for testing. This directory should be located in the directory of each test case. If not found, the test will not deploy any Terraform configurations during testing.
  "testTerraformStateFileName": "terraform_state.tfstate", //name of the terraform state file used for testing. This file will be created in the same directory as the test scripts during testing.
  "testTerraformEncryptedStateFileName": "terraform_state.enc", //name of the encrypted terraform state file used for testing. This file will be created in the same directory as the test scripts during testing.
  "testLocalConfigFileName": "config.json", //name of the local configuration file used for testing. This file will be created in the same directory as the test scripts during testing and will contain the configuration for the tests.
  "initialEvalMaximumWaitTime": 20, //maximum wait time in minutes for the initial evaluation of the policy assignment to complete. This is needed to ensure that the tests do not proceed until the policy assignment is fully evaluated and any non-compliant resources are identified.
  "whatIfMaxRetry": 5, //maximum number of retries for the What-If deployment operation in case of transient failures. This is needed to improve the reliability of the tests by allowing for retries in case of temporary issues with the deployment.
  "testScriptName": "tests.ps1", //Name of the test script used for testing. This script should be located in the directory of each test case.
  "testOutputFilePrefix": "TEST-Resource-Config", //prefix to be applied to the names of the output files generated by the tests. This helps to easily identify and filter test output files in the Azure portal and in the test results.
  "testOutputFormat": "NUnitXml", //Pester test output format
  "testBicepDeploymentOutputArtifactPrefix": "intTestBicepDeployResult", //prefix to be applied to the names of the Bicep output artifacts generated by each Policy Integration test.
  "testTerraformDeploymentOutputArtifactPrefix": "intTestTFDeployResult", //prefix to be applied to the names of the Terraform output artifacts generated by each Policy Integration test.
  "testDeploymentOutputFileName": "result.json", //name of the output file generated by the tests.
  "buildId": "0000", //Dummy build Id when running tests locally. In the pipeline, this value will be overridden by the actual build Id from the pipeline variables.
  //Subscriptions and details about the each subscription used in the tests. This is needed to provide the necessary information for the tests to create and manage resources in the correct subscriptions and resource groups.
  "subscriptions": {
    "sub-d-mgmt-01": {
      "id": "f27ab1cb-9c1a-4bdb-9e18-bb11ec9205db",
      "networkResourceGroup": "rg-dev-network-01",
      "vNet": "vnet-ae-dev-network-01",
      "peSubnet": "sn-private-endpoint",
      "amplsSubnet": "sn-monitor",
      "resourceSubnet": "sn-resources",
      "containerAppSubnet": "sn-container-app",
      "caontainerAppPeSubnet": "sn-container-app-pe"
    },
    "sub-d-lz-corp-01": {
      "id": "f793e6e7-9219-4d57-8582-89bb7be49bba",
      "networkResourceGroup": "rg-lz-corp-d-network-01",
      "vNet": "vnet-ae-lz-d-corp-network-01",
      "peSubnet": "sn-private-endpoint",
      "amplsSubnet": "sn-monitor",
      "resourceSubnet": "sn-resources"
    }
  },
  "TestTriggers": {
    //Path where the policy definitions, initiatives, and assignment configurations are stored. These paths are used to determine which test cases to trigger based on the files that were changed.
    "policyDefinitionsPath": "policyDefinitions",
    "policyInitiativesPath": "policyInitiatives",
    "policyAssignmentsPath": "policyAssignments/dev",
    "policyIntegrationTestsPath": "tests/policy-integration-tests",
    "policyAssignmentConfigurationJsonPathForAssignmentName": "name",
    "policyAssignmentConfigurationJsonPathForPolicyDefinitionId": "policyDefinitionId",
    //globalTestPaths defines the the files and directories that will trigger all test cases if changes are detected.
    "globalTestPaths": [
      "tests/policy-integration-tests/.shared/policy_integration_test_config.jsonc",
      "templates/policyAssignments",
      "templates/policyDefinitions",
      "templates/policyInitiatives",
      "pipelines/pr-validation/azure-pipelines-pr-policy-int-tests.yml",
      "pipelines/policies/azure-pipelines-policy-assignments.yml",
      "pipelines/policies/azure-pipelines-policy-definitions.yml",
      "pipelines/policies/azure-pipelines-policy-initiatives.yml",
      "pipelines/templates/template-stage-initiation.yml",
      "pipelines/templates/template-stage-policy-assignment-build.yml",
      "pipelines/templates/template-job-test-and-validate.yml",
      "pipelines/templates/template-job-get-parameter-files.yml",
      "pipelines/templates/template-stage-multiple-deployments.yml",
      "pipelines/templates/template-stage-policy-def-build.yml",
      "pipelines/templates/template-stage-policy-tests.yml",
      "pipelines/templates/template-job-detect-policy-integration-test-cases.yml",
      "pipelines/templates/template-job-get-sub-directories.yml",
      "pipelines/templates/template-task-install-ps-modules.yml",
      "pipelines/templates/template-stage-policy-integration-tests.yml",
      "scripts/pipelines/helper",
      "scripts/pipelines/policy-integration-tests",
      "scripts/pipelines/pipeline-get-deployment-target-from-parameter-file.ps1",
      "scripts/pipelines/pipeline-get-parameter-files.ps1",
      "scripts/pipelines/pipeline-get-sub-directories.ps1",
      "scripts/pipelines/pipeline-install-moduleFromRepo.ps1",
      "scripts/pipelines/pipeline-template-deployment.ps1",
      "scripts/pipelines/pipeline-template-deployment-rest.ps1",
      "scripts/pipelines/pipeline-template-validation.ps1",
      "scripts/pipelines/pipeline-set-policy-resource-bicep-template-file.ps1",
      "scripts/pipelines/pipeline-set-policy-non-compliance-messages.ps1",
      "ps_modules/AzResourceTest"
    ],
    //ignoredFiles defines the files and file types that will be ignored when detecting changes for triggering test cases. Changes to these files will not trigger any tests.
    "ignoredFiles": [
      "*.md",
      ".gitignore",
      "markdownlint.json",
      "ps-rule.yaml",
      "bicepconfig.json",
      "*.xml",
      "*.nuspec",
      ".testignore"
    ]
  }
}